                     : new TeleportTransition(
                         currentLevel,
                         teleportPosition,
@@ -124,9 +126,10 @@ public class EndGatewayBlock extends BaseEntityBlock implements Portal {
                         0.0F,
                         0.0F,
                         Relative.union(Relative.DELTA, Relative.ROTATION),
-                        TeleportTransition.PLACE_PORTAL_TICKET,
+                        postTeleportTransition,
                         org.bukkit.event.player.PlayerTeleportEvent.TeleportCause.END_GATEWAY // CraftBukkit
                     );
+                // Leaves end - Disable end gateway portal entity ticking
             }
         } else {
