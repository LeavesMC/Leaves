diff --git a/net/minecraft/server/level/ServerPlayer.java b/net/minecraft/server/level/ServerPlayer.java
index 8fad9a4b55b32bee6fef42f959136e37802f03be..f4a4896061884ef6e86f3d7589f4c6b6ad84dc5f 100644
--- a/net/minecraft/server/level/ServerPlayer.java
+++ b/net/minecraft/server/level/ServerPlayer.java
@@ -1222,7 +1222,7 @@ public class ServerPlayer extends Player implements ca.spottedleaf.moonrise.patc
         }
 
         // SPIGOT-5478 must be called manually now
-        if (event.shouldDropExperience()) this.dropExperience(this.level(), source.getEntity()); // Paper - tie to event
+        if (shouldDropExperience(event.shouldDropExperience(), event.forceUseEventDropStatus())) this.dropExperience(this.level(), source.getEntity()); // Paper - tie to event // Leaves - exp fix
         // we clean the player's inventory after the EntityDeathEvent is called so plugins can get the exact state of the inventory.
         if (!event.getKeepInventory()) {
             // Paper start - PlayerDeathEvent#getItemsToKeep
@@ -1269,6 +1269,15 @@ public class ServerPlayer extends Player implements ca.spottedleaf.moonrise.patc
         this.connection.markClientUnloadedAfterDeath();
     }
 
+    // Leaves start - exp fix
+    private boolean shouldDropExperience(final boolean eventResult, final boolean forceUseEvent) {
+        if (forceUseEvent) {
+            return eventResult;
+        }
+        return !this.wasExperienceConsumed() && eventResult;
+    }
+    // Leaves end - exp fix
+
     private void tellNeutralMobsThatIDied() {
         AABB aabb = new AABB(this.blockPosition()).inflate(32.0, 10.0, 32.0);
         this.level()
