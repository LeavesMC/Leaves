                 } else if (targetItemStack.isEmpty()) {
                     if (target.mayPlace(source)) {
                         int maxStackSize = target.getMaxStackSize(source);
-                        if (source.getCount() > maxStackSize) {
+                        if (!org.leavesmc.leaves.LeavesConfig.modify.oldMC.allowGrindstoneOverstacking && source.getCount() > maxStackSize) { // Leaves - grindstone overstacking
                             target.setByPlayer(source.split(maxStackSize));
                         } else {
                             inventory.setItem(buttonNum, ItemStack.EMPTY);
@@ -611,7 +611,7 @@ public abstract class AbstractContainerMenu {
                     }
                 } else if (target.mayPickup(player) && target.mayPlace(source)) {
                     int maxStackSize = target.getMaxStackSize(source);
-                    if (source.getCount() > maxStackSize) {
+                    if (!org.leavesmc.leaves.LeavesConfig.modify.oldMC.allowGrindstoneOverstacking && source.getCount() > maxStackSize) { // Leaves - grindstone overstacking
                         target.setByPlayer(source.split(maxStackSize));
                         target.onTake(player, targetItemStack);
                         if (!inventory.add(targetItemStack)) {
@@ -768,6 +768,10 @@ public abstract class AbstractContainerMenu {
         return this.moveItemStackTo(itemStack, startSlot, endSlot, backwards, false);
     }
     protected boolean moveItemStackTo(ItemStack itemStack, final int startSlot, final int endSlot, final boolean backwards, final boolean isCheck) { // Paper - Add PlayerTradeEvent and PlayerPurchaseEvent - non-final itemStack
+        // Leaves - Add force move
+        return this.moveItemStackTo(itemStack, startSlot, endSlot, backwards, isCheck, false);
+    }
+    protected boolean moveItemStackTo(ItemStack itemStack, final int startSlot, final int endSlot, final boolean backwards, final boolean isCheck, final boolean forceMove) { // Leaves - Add force move
         if (isCheck) {
             itemStack = itemStack.copy();
         }
@@ -832,6 +836,14 @@ public abstract class AbstractContainerMenu {
                 // Paper end - Add PlayerTradeEvent and PlayerPurchaseEvent
                 if (targetx.isEmpty() && slotx.mayPlace(itemStack)) {
                     int maxStackSize = slotx.getMaxStackSize(itemStack);
+                    // Leaves start - Add force move
+                    if (forceMove) {
+                        slotx.setByPlayer(itemStack.split(itemStack.getCount()));
+                        slotx.setChanged();
+                        anythingChanged = true;
+                        break;
+                    }
+                    // Leaves end - Add force move
                     // Paper start - Add PlayerTradeEvent and PlayerPurchaseEvent
                     if (isCheck) {
                         itemStack.shrink(Math.min(itemStack.getCount(), maxStackSize));
diff --git a/net/minecraft/world/inventory/GrindstoneMenu.java b/net/minecraft/world/inventory/GrindstoneMenu.java
index 945ffd3b7f3dc5c5bf6b35d015b3da0736342c8b..67ae3d359329bd61b430bfa1bad1b729eb29b0be 100644
