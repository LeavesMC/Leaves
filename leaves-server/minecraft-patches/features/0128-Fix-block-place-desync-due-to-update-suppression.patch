From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Leaves <leaves@leaves>
Date: Thu, 16 Apr 2026 11:19:16 +0800
Subject: [PATCH 06/11] Fix block place desync due to update suppression


diff --git a/net/minecraft/world/item/ItemStack.java b/net/minecraft/world/item/ItemStack.java
index 4ad60bf371ed2718d6d9ce90c5812c9b81e0976a..cd7b18263adcdb8ac25d5f5adcaa8cec1ce7af14 100644
--- a/net/minecraft/world/item/ItemStack.java
+++ b/net/minecraft/world/item/ItemStack.java
@@ -393,8 +393,18 @@ public final class ItemStack implements DataComponentHolder, ItemInstance {
                 }
             }
             InteractionResult result;
+            // Leaves start - fix block place desync due to update suppression
+            org.leavesmc.leaves.util.UpdateSuppressionException ue = null;
             try {
                 result = usedItem.useOn(context);
+            } catch (org.leavesmc.leaves.util.UpdateSuppressionException ex) {
+                result = InteractionResult.SUCCESS.configurePaper(e -> e.placedBlockAt(pos.immutable()));
+                ue = ex;
+                ue.provideBlock(context.getLevel(), context.getClickedPos(), level.getBlockState(context.getClickedPos()).getBlock());
+                if (player != null) {
+                    ue.providePlayer((net.minecraft.server.level.ServerPlayer) player);
+                }
+            // Leaves end - fix block place desync due to update suppression
             } finally {
                 level.captureBlockStates = false;
             }
@@ -540,6 +550,7 @@ public final class ItemStack implements DataComponentHolder, ItemInstance {
             level.capturedBlockStates.clear();
             // CraftBukkit end
 
+            if (ue != null) throw ue; // Leaves - fix block place desync due to update suppression
             return result;
         }
     }
