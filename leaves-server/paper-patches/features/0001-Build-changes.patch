+            final PlayerTeleportEvent.TeleportCause cause = switch (type) {
+                case PortalType.ENDER -> PlayerTeleportEvent.TeleportCause.END_PORTAL;
+                case PortalType.NETHER -> PlayerTeleportEvent.TeleportCause.NETHER_PORTAL;
